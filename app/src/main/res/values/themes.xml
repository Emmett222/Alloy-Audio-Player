<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AlloyAudioPlayer" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
  <!-- Base application theme. -->
    <style name="CircleShapeAppearance" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Base.Theme.AlloyAudioPlayer" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.AlloyAudioPlayer.PlayerLaunch" parent="Base.Theme.AlloyAudioPlayer">
        <item name="android:windowBackground">@color/dark_green</item>

        <item name="android:windowDisablePreview">false</item>
    </style>
</resources>