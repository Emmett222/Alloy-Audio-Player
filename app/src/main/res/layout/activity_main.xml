<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_title">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageButton
            android:id="@+id/button"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="32dp"
            android:background="#0d380c"
            android:scaleType="centerCrop"
            android:src="@drawable/title_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#00FF00" />

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button"
            app:srcCompat="@drawable/background_line" />

        <ImageView
            android:id="@+id/iconPlaylist"
            android:layout_width="48dp"
            android:layout_height="0dp"
            android:layout_marginStart="32dp"
            android:background="#0d380c"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/textView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView"
            app:tint="#00FF00"
            app:srcCompat="@drawable/menu_queue" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            android:background="#0d380c"
            android:padding="10dp"
            android:text="Playlists"
            android:textColor="#00FF00"
            android:textSize="20dp"
            app:layout_constraintEnd_toStartOf="@+id/playlistBtn"
            app:layout_constraintStart_toEndOf="@+id/iconPlaylist"
            app:layout_constraintTop_toBottomOf="@+id/imageView2" />

        <ImageButton
            android:id="@+id/playlistBtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="32dp"
            android:background="@android:color/transparent"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@+id/textView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView"
            app:srcCompat="@drawable/btn_menu" />

        <ImageView
            android:id="@+id/iconFiles"
            android:layout_width="48dp"
            android:layout_height="0dp"
            android:layout_marginStart="32dp"
            android:background="#0d380c"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/textView2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView2"
            app:tint="#00FF00"
            app:srcCompat="@drawable/menu_files" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:background="#0d380c"
            android:padding="10dp"
            android:text="Files"
            android:textColor="#00FF00"
            android:textSize="20dp"
            app:layout_constraintEnd_toStartOf="@+id/filesBtn"
            app:layout_constraintStart_toEndOf="@+id/iconFiles"
            app:layout_constraintTop_toBottomOf="@+id/textView" />

        <ImageButton
            android:id="@+id/filesBtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="32dp"
            android:background="@android:color/transparent"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@+id/textView2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView2"
            app:srcCompat="@drawable/btn_menu" />

        <ImageView
            android:id="@+id/iconWn"
            android:layout_width="48dp"
            android:layout_height="0dp"
            android:layout_marginStart="32dp"
            android:background="#0d380c"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/textView3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView3"
            app:tint="#00FF00"
            app:srcCompat="@drawable/menu_wn" />

        <TextView
            android:id="@+id/textView3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:background="#0d380c"
            android:padding="10dp"
            android:text="White Noise"
            android:textColor="#00FF00"
            android:textSize="20dp"
            app:layout_constraintEnd_toStartOf="@+id/wnBtn"
            app:layout_constraintStart_toEndOf="@+id/iconWn"
            app:layout_constraintTop_toBottomOf="@+id/textView2" />

        <ImageButton
            android:id="@+id/wnBtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="32dp"
            android:background="@android:color/transparent"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@+id/textView3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView3"
            app:srcCompat="@drawable/btn_menu" />

        <ImageView
            android:id="@+id/iconSettings"
            android:layout_width="48dp"
            android:layout_height="0dp"
            android:layout_marginStart="32dp"
            android:background="#0d380c"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/textView4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView4"
            app:tint="#00FF00"
            app:srcCompat="@drawable/menu_settings" />

        <TextView
            android:id="@+id/textView4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:background="#0d380c"
            android:padding="10dp"
            android:text="Settings"
            android:textColor="#00FF00"
            android:textSize="20dp"
            app:layout_constraintEnd_toStartOf="@+id/settingsBtn"
            app:layout_constraintStart_toEndOf="@+id/iconSettings"
            app:layout_constraintTop_toBottomOf="@+id/textView3" />

        <ImageButton
            android:id="@+id/settingsBtn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="32dp"
            android:background="@android:color/transparent"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="@+id/textView4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView4"
            app:srcCompat="@drawable/btn_menu" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>