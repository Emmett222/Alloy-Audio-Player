<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Layer 0: Your original background -->
    <item android:drawable="@drawable/background4" />

    <!-- Layer 1: The Dark Gray Border -->
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="#333333" /> <!-- Dark Gray -->


            <!-- Adjust this radius to match the rounding of your brushed metal UI -->
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>